# Edge Function environment variables.
# Copy to supabase/functions/.env for local `supabase functions serve`.
# In production, set these in Supabase Dashboard → Edge Functions → Secrets.

# Australian Business Register Web Services GUID.
# Free registration at https://abr.business.gov.au/Tools/WebServices.
ABR_GUID=

# Dev-mode toggle for verify-abn while waiting on the real ABR GUID.
# When "true": skips checksum validation, returns deterministic mock responses
# based on ABN suffix (see supabase/functions/README.md). DO NOT set this in
# production — leave blank or set to "false".
ABR_DEV_MODE=true

# Service-role key — required for Edge Functions to bypass RLS on
# verifications / verification_events / verification_rate_limits / regulator_circuit_state.
# DO NOT commit. DO NOT ship to client code.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL. Same value as the Flutter app's SUPABASE_URL.
SUPABASE_URL=

# Optional Sentry DSN for Edge Function error reporting. Empty = no-op.
SENTRY_DSN=
