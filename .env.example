# ============================================================================
# CLIENT-SAFE ENV  —  this file (.env) is BUNDLED INTO THE APP as a flutter
# asset (see pubspec.yaml). Everything here ships inside every APK/IPA and is
# trivially extractable. Put ONLY public client keys here.
# Server secrets (service-role key, Twilio tokens, ABR GUID) go in .env.server
# — gitignored and NEVER bundled. See .env.server.example.
# validate.sh fails the build if a server secret leaks into this file.
# ============================================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google Sign-In OAuth client IDs (public client identifiers, safe to bundle).
# console.cloud.google.com → APIs & Credentials → OAuth 2.0 Client IDs.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# MapTiler Geocoding — AU-restricted suburb/address autocomplete.
# Get a free key at https://www.maptiler.com/cloud/ and restrict it to the
# Geocoding API + your Android package + iOS bundle ID. Free tier covers
# 100,000 requests/month. Optional — without it, the location picker falls
# back to the legacy 3-field manual input.
MAPTILER_API_KEY=

# Sentry crash reporting. Optional — empty value means Sentry initialises
# with no DSN and silently no-ops, so dev builds run normally. Get the DSN
# from https://sentry.io → Settings → Projects → <jobdun-mobile> → Client Keys.
SENTRY_DSN=
# Environment tag that shows on every event in the Sentry dashboard. Common
# values: development, staging, production. Defaults to "development".
SENTRY_ENVIRONMENT=development
