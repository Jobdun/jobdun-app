SUPABASE_URL=
SUPABASE_ANON_KEY=

# MapTiler Geocoding — AU-restricted suburb/address autocomplete.
# Get a free key at https://www.maptiler.com/cloud/ and restrict it to the
# Geocoding API + your Android package + iOS bundle ID. Free tier covers
# 100,000 requests/month. Optional — without it, the location picker falls
# back to the legacy 3-field manual input.
MAPTILER_API_KEY=

# Sentry crash reporting. Optional — empty value means Sentry initialises
# with no DSN and silently no-ops, so dev builds run normally. Get the DSN
# from https://sentry.io → Settings → Projects → <jobdun-mobile> → Client Keys.
SENTRY_DSN=
# Environment tag that shows on every event in the Sentry dashboard. Common
# values: development, staging, production. Defaults to "development".
SENTRY_ENVIRONMENT=development
