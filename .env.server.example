# ============================================================================
# SERVER-ONLY SECRETS  —  NEVER bundled into the app. Gitignored (.env.*).
# Copy to .env.server and fill in. Do NOT move any of these into .env, which
# ships inside the app binary (validate.sh enforces this).
#
# Consumers:
#   - supabase CLI: config.toml reads env(SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN)
#   - edge-function deploy / admin SQL: SUPABASE_SERVICE_ROLE_KEY
#   - ABR licence/ABN verification edge function: ABR_GUID
#
# Load into your shell when running those tools:
#   set -a; source .env.server; set +a
# ============================================================================

# Supabase service-role key — FULL database access, bypasses RLS. Server only.
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (SMS / phone-OTP auth via Supabase Auth + messaging).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SENDER_NUMBER=

# Australian Business Register GUID — used by the verify-abn edge function.
ABR_GUID=

# Developer test phone (PII — kept out of the app bundle).
KEN_DEV_PHONE=
