# Copy this file to scripts/.ship-env and fill in FIREBASE_APP_ID.
# scripts/.ship-env is gitignored — your keys never get committed.
#
# Supabase + all other app keys are read automatically from .env at repo root
# (the same file `flutter run` uses), so the only thing to set here is the
# Firebase App ID.

# Firebase Android App ID.
#   Where: Firebase Console -> gear icon (Project settings) -> "Your apps"
#          -> your Android app -> copy the "App ID".
#   NOTE: this is NOT the project id. It looks like:
#          1:123456789012:android:abc123def456
FIREBASE_APP_ID=paste_your_firebase_android_app_id_here

# Tester group you created in App Distribution (default: boss).
TESTER_GROUP=boss
